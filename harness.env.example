# harness.env — per-project configuration for the agent harness.
#
# Copy to `harness.env` and fill in. Every script sources this file from the
# repo root. Leave a command BLANK to skip that step entirely — the harness
# adapts to projects with no stack, no e2e, etc.
#
#   cp harness.env.example harness.env

# ── init.sh: bringing the stack up ────────────────────────────────────────
# Idempotent command to start your app/stack. Blank = nothing to start.
UP_CMD="docker compose up -d --build"

# Health endpoint polled after UP_CMD until it returns 2xx. Blank = skip.
HEALTH_URL="http://localhost:5000/health"
HEALTH_TIMEOUT=90

# Space-separated tools that must be on PATH before any work begins.
# (jq is always required by the harness itself and is checked separately.)
REQUIRED_TOOLS="docker curl"

# ── verify.sh: the three layers (Definition of Done) ──────────────────────
# Run in order, stop on first failure. Blank = skip that layer.
VERIFY_STATIC="dotnet build -warnaserror"   # lint / typecheck / compile
VERIFY_UNIT="dotnet test"                    # unit tests
VERIFY_E2E="bash scripts/e2e.sh"             # end-to-end (needs running stack)
VERIFY_UI=""                                 # opt-in browser suite (RUN_UI=1)

# ── pre-commit: when to run verify on commit ──────────────────────────────
# Regex of staged paths that should trigger verify. Blank = always run.
VERIFY_PATH_FILTER="^(src|backend|frontend)/"

# ── handoff.sh: debug-artifact scan ───────────────────────────────────────
# Space-separated regexes. An ADDED line (git diff) matching any one blocks
# handoff. Defaults below catch the usual suspects across JS/TS/C#/Python.
DEBUG_PATTERNS='console\.log debugger; //[[:space:]]*TODO Console\.WriteLine print\((["'"'"']DEBUG)'

# ── parallel development ───────────────────────────────────────────────────
# DISTRIBUTED parallel-safe workflow is the DEFAULT and needs no config: the
# work queue is one file per ticket (features/<id>.json) so concurrent branches
# never conflict on it, depends_on / ready-frontier picks the next ticket, and
# the append-only docs union-merge (.gitattributes). It works across any number
# of separate clones / machines out of the box. See README "Parallel development".
#
# LOCAL parallel (optional) — running several git worktrees on ONE machine. Each
# worktree gets its OWN docker-compose project with kernel-assigned host ports
# (discovered into .agent/env) so they never collide on a port or container.
# REQUIRES a machine that can run several stacks at once AND a docker-compose
# UP_CMD. Leave 0 if you only ever run one stack on this machine — you still get
# the distributed workflow across separate clones.
PER_STREAM_STACKS=0

# Per-stream health probe (PER_STREAM_STACKS=1 only): which compose SERVICE
# publishes the health endpoint, the CONTAINER port it listens on (the HOST port
# is discovered at runtime), and the path to poll. init.sh builds HEALTH_URL from
# the discovered host port and writes it to .agent/env for the other scripts.
STACK_HEALTH_SERVICE="api"
STACK_HEALTH_CONTAINER_PORT="8080"
STACK_HEALTH_PATH="/health"
